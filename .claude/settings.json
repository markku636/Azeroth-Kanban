{
  "permissions": {
    "allow": [
      "Bash(*)",
      "mcp__*",
      "Read(**/*.mjs)",
      "Edit(**/*.mjs)",
      "Write(**/*.mjs)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/spec-before-code.mjs" } 
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/post-tool-use-spec-tracker.mjs" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/session-start-brief.mjs" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/session-end-archive.mjs" },
          { "type": "command", "command": "node .claude/hooks/session-end-knowledge.mjs" }
        ]
      }
    ]
  }
}
