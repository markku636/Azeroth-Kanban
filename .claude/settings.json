{
  "permissions": {
    "allow": [
      "Bash(*)",
      "mcp__*",
      "Read(**/*.mjs)",
      "Edit(**/*.mjs)",
      "Write(**/*.mjs)",
      "Read(.tmp/**)",
      "Write(.tmp/**)",
      "Edit(.tmp/**)",
      "Read(docs/**/*.md)",
      "Write(docs/**/*.md)",
      "Edit(docs/**/*.md)",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__fill_form"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/spec-before-code.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-tool-use-spec-tracker.mjs"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-start-brief.mjs"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-end-archive.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/session-end-knowledge.mjs"
          }
        ]
      }
    ]
  }
}
