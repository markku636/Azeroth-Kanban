# ─── PostgreSQL ───
DATABASE_URL="postgresql://kanban:kanban_secret@localhost:5444/kanban?schema=public"

# ─── NextAuth v5（AUTH_SECRET 至少 32 字）───
NEXTAUTH_URL="http://localhost:3010"
AUTH_SECRET="your-auth-secret-change-me-at-least-32-chars"
AUTH_TRUST_HOST="true"

# ─── Keycloak OIDC（主要登入方式）───
AUTH_KEYCLOAK_ID="kanban-admin"
AUTH_KEYCLOAK_SECRET="kanban-admin-secret"
AUTH_KEYCLOAK_ISSUER="http://localhost:8080/realms/kanban"

# ─── 登入流程設定 ───
# 帳密登入：admin 啟用 CredentialsProvider（接受 prisma seed 預設帳號）；Demo 預設 true
AUTH_ALLOW_CREDENTIALS="true"
# Keycloak SSO 按鈕：登入頁是否顯示；預設不顯示，避免導向 Keycloak
NEXT_PUBLIC_AUTH_KEYCLOAK_ENABLED="false"

# ─── 對外 status page (/status) ───
# 公開狀態頁的存取金鑰。要看 /status 需在網址帶 ?key=<此值>。
# 留空 = 整個 status page 停用（API 回 503）。要完全公開請改 route.ts 拿掉 key 檢查。
STATUS_PAGE_KEY=""
