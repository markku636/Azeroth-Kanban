# 根目錄 .env.example — 複製為 .env 後依需求調整
# 供 docker-compose / Claude Code .mcp.json 的 ${VAR} 插值使用

# ─── PostgreSQL ───
POSTGRES_USER=kanban
POSTGRES_PASSWORD=kanban_secret
POSTGRES_DB=kanban
DATABASE_URL="postgresql://kanban:kanban_secret@localhost:5444/kanban"

# ─── Keycloak（admin 帳號 / 預設 SSO 使用者由 realm-export.json 提供）───
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ─── NextAuth ───
AUTH_SECRET=your-auth-secret-change-me-at-least-32-chars

# ─── Keycloak Client（admin app 用）───
AUTH_KEYCLOAK_ID=kanban-admin
AUTH_KEYCLOAK_SECRET=kanban-admin-secret
# 容器化部署（docker compose）使用 host.docker.internal，確保 admin 容器與瀏覽器走同一 URL
# 本機 npm run dev 開發時，請改為 http://localhost:8080/realms/kanban
AUTH_KEYCLOAK_ISSUER=http://host.docker.internal:8080/realms/kanban

# ─── 登入流程設定 ───
# 帳密登入：admin 啟用 CredentialsProvider；Demo 預設 true
AUTH_ALLOW_CREDENTIALS=true
# Keycloak SSO 按鈕：登入頁是否顯示「以 Keycloak 登入」按鈕；預設不顯示，避免導向 Keycloak
NEXT_PUBLIC_AUTH_KEYCLOAK_ENABLED=false

# ─── Seed 控制 ───
# 預設 true：admin 啟動時自動跑 prisma seed（upsert，安全可重複執行）
# 想跳過（例如已手動修改過預設使用者）設為 false
SEED_ON_START=true

# ─── Selkie agent — Gemini on Vertex AI ───
# Selkie 事故調查 agent 需要。GCP 專案需先啟用 Vertex AI API 並有可用配額。
# 憑證:把 service account JSON 放專案根目錄、命名 service-account.json;
#       本機開發也可改用 `gcloud auth application-default login`。
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MODEL_FAST=gemini-2.5-flash-lite
# 每個模型的並發呼叫上限;低配額專案維持 1(序列化呼叫,避免 429)
GEMINI_MAX_CONCURRENCY=1

# ─── Selkie 工具後端 ───
# mock：內建假資料(離線可用,單元測試用);real：查真實的 Elasticsearch。
# docker compose 已對 admin 服務寫死 TOOL_BACKEND=real;本機 npm run dev 預設 mock。
TOOL_BACKEND=mock
# real 後端查詢的 Elasticsearch 位址(docker 內為 http://elasticsearch:9200)
ELASTICSEARCH_URL=http://localhost:9200

# ─── 告警 webhook ───
# admin 的 /api/v1/webhooks/alerts/[source] 與 simulator 共用此密鑰
SELKIE_WEBHOOK_SECRET=selkie-dev-secret
